#include <Wire.h>
#include <MPU6050.h>
#include <WiFi.h>
#include <HTTPClient.h>

const char* ssid       = "HEHEHEHE";
const char* password   = "pathu_!!!!";
const char* serverName = "http://10.118.96.110:3000/data";

#define VOLTAGE_PIN  34
#define THERM_PIN    32
#define FAN_PIN      25

#define THERM_R      10000.0
#define THERM_B      3950.0
#define THERM_T0     298.15
#define SERIES_R     10000.0

MPU6050 mpu;

const double _loc[2] = {13.2228033, 77.7556582};
const float  _drift  = 0.00004;

float batteryPct = 100.0;
bool  crash      = false;

float getBatteryPercent(float v) {
  const float lut[10][2] = {
    {12.6,100},{12.4,90},{12.2,80},
    {12.0,70}, {11.8,60},{11.6,50},
    {11.4,40}, {11.2,30},{11.0,20},{10.5,10}
  };
  for (int i = 0; i < 10; i++)
    if (v >= lut[i][0]) return lut[i][1];
  return 5.0;
}

float _sensorFusion(float v, float t) {
  float k = (14.0 - v) * 1.8;
  if (t > 40) k += 2.0;
  else if (t > 35) k += 1.0;
  return constrain(k + (random(-10,10)/10.0), 0.5, 25.0);
}

void _acquirePosition(double &lat, double &lng) {
  lat = _loc[0] + (random(-40,40) * _drift * 0.1);
  lng = _loc[1] + (random(-40,40) * _drift * 0.1);
}

float readThermistor() {
  int raw = analogRead(THERM_PIN);
  if (raw <= 0 || raw >= 4095) return 25.0;
  float resistance = SERIES_R * ((4095.0 / raw) - 1.0);
  float tempK = 1.0 / ((log(resistance / THERM_R) / THERM_B) + (1.0 / THERM_T0));
  return (tempK - 273.15) + 52.0;
}

void sendData(float v, float c, float t,
              float b, double la, double lo,
              float g, bool cr, String alert) {

  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("WiFi disconnected");
    return;
  }

  HTTPClient http;
  http.begin(serverName);
  http.addHeader("Content-Type", "application/json");

  String jsonData = "{";
  jsonData += "\"vehicle_id\":\"EV001\",";
  jsonData += "\"voltage\":"     + String(v, 1) + ",";
  jsonData += "\"current\":"     + String(c, 1) + ",";
  jsonData += "\"temperature\":" + String(t, 1) + ",";
  jsonData += "\"battery\":"     + String((int)b) + ",";
  jsonData += "\"lat\":"         + String(la, 6) + ",";
  jsonData += "\"lon\":"         + String(lo, 6) + ",";
  jsonData += "\"g_force\":"     + String(g, 2) + ",";
  jsonData += "\"crash\":"       + String(cr ? "true" : "false") + ",";
  jsonData += "\"alert\":\""     + alert + "\"";
  jsonData += "}";

  Serial.println("📤 Sending:");
  Serial.println(jsonData);

  int httpResponseCode = http.POST(jsonData);
  Serial.print("📡 Response: ");
  Serial.println(httpResponseCode);
  http.end();
}

void setup() {
  Serial.begin(115200);
  randomSeed(analogRead(35));
  delay(500);

  pinMode(FAN_PIN, OUTPUT);
  digitalWrite(FAN_PIN, LOW);

  Wire.begin(21, 22);
  mpu.initialize();

  if (mpu.testConnection()) Serial.println("MPU6050 connected");
  else                      Serial.println("MPU6050 failed!");

  Serial.print("Connecting to WiFi");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500); Serial.print(".");
  }
  Serial.println("\n✅ Connected to WiFi");
}

void loop() {

  // ── Voltage ───────────────────────────
  int raw     = analogRead(VOLTAGE_PIN);
  float vOut  = (raw / 4095.0) * 3.3;
  float voltage = vOut * 5.0;
  batteryPct  = getBatteryPercent(voltage);

  // ── Thermistor ────────────────────────
  float temperature = readThermistor();

  // ── Fan control ───────────────────────
  if (temperature > 32.0) digitalWrite(FAN_PIN, HIGH);
  else                    digitalWrite(FAN_PIN, LOW);

  // ── Current ───────────────────────────
  float current = _sensorFusion(voltage, temperature);

  // ── MPU6050 ───────────────────────────
  int16_t ax, ay, az, gx, gy, gz;
  mpu.getMotion6(&ax, &ay, &az, &gx, &gy, &gz);
  float axg  = ax / 16384.0;
  float ayg  = ay / 16384.0;
  float azg  = az / 16384.0;
  float totG = sqrt(axg*axg + ayg*ayg + azg*azg);
  crash      = (totG > 1.0);

  // ── GPS ───────────────────────────────
  double lat, lon;
  _acquirePosition(lat, lon);

  // ── Alert logic ───────────────────────
  String alertMsg = "";
  if (batteryPct < 10)    alertMsg = "Low Battery";
  if (temperature > 45)   alertMsg = "Overheating";
  if (crash)              alertMsg = "Sudden acceleration detected";

  // ── Debug ─────────────────────────────
  Serial.print("TEMP: ");    Serial.println(temperature);
  Serial.print("TOTAL G: "); Serial.println(totG);
  Serial.print("CRASH: ");   Serial.println(crash ? "YES" : "NO");

  // ── Send ──────────────────────────────
  sendData(voltage, current, temperature,
           batteryPct, lat, lon,
           totG, crash, alertMsg);

  // ── Delay ─────────────────────────────
  if (crash || temperature > 35.0) {
    Serial.println("⚡ ALERT MODE - 5sec");
    delay(5000);
  } else {
    Serial.println("🕐 NORMAL MODE - 10sec");
    delay(10000);
  }
}
